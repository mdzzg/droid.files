[core]
	editor = code-insiders --wait
	excludesfile = /home/madz/.config/git/ignore
	autocrlf = input
	fileMode = false
	attributesfile = /home/madz/.config/git/attributes/.gitattributes
[alias]
	cnfg = config --global -l
	cnfge = config --global -e

	ad = add .					# Adds all new, modified, and deleted files in the current directory and its subdirectories to the staging area - Works recursively from the current directory downwards
	adu = add -u				# Adds only modified and deleted files to the staging area, but not new files - Operates only on tracked files in the working directory
	adr = add . --renormalize	# Normalize inconsistent line endings in the repo
	adru = add --renormalize -u	# Normalize inconsistent line endings of the previously tracked files of the repo
	
	ct = commit -m
	u = push
	pl = pull
	
	ls = ls-files
	graph = log --all --graph --oneline --date=format:'%g-%m-%d %R' --pretty=format:'%C(yellow)%h | %C(reset)%C(red)%C(bold)%cd | %C(reset)%C(bold)%s%C(reset)%C(blue) <- %cn'
	# graph = log --all --graph --oneline --date=format:%Y-%m-%d\ %H:%M --pretty=format:"%C(yellow)%h %Creset%C(red)%C(bold)%cd %Creset%C(bold)%s%Creset%C(blue) <- %cn"
	# log --oneline --decorate --all --graph
	# ls = log --pretty=format:"%C(yellow)%h%Cred%d\\ %Creset%s%Cblue\\ [%cn]" --decorate
	
	br = branch
	bra = branch -a
	brr = branch -r				# List remote branches
	brm = branch -M				# M - shortcut for --move --force

	rt = remote -v
	rta = remote add

	st = status					# 'status' is protected name so using 'st' instead
	tg = tag					# Creates a lightweight tag: Contains no additional metadata, such as a tag message or an author
	ntg = tag -a				# Creates an annotated tag: Contains a tag message, the name of the person who created the tag, the date of the tag
	
	difn = diff --name-only		#	compares all files, shows only names of changed files
	#	dift = difftool default	#	compares all files, 1-by-1, sequentially
	
